# Server Configuration
PORT=8080
ENVIRONMENT=development

# Database Configuration
DATABASE_URL=postgres://postgres:password@localhost:5432/quikprint?sslmode=disable

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRY_HOURS=24
JWT_REFRESH_EXPIRY_HOURS=168

# Paystack Configuration
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_key
PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public_key
PAYSTACK_CALLBACK_URL=http://localhost:5173/checkout/callback

# File Upload Configuration
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Shipping Configuration (in Naira)
# Amount charged for orders below the free shipping threshold
SHIPPING_FEE=5000
# Orders above this amount get free shipping
FREE_SHIPPING_THRESHOLD=50000

# Admin Default Credentials (for initial setup)
ADMIN_EMAIL=admin@quikprint.com
ADMIN_PASSWORD=admin123

# SMTP Configuration (Hostinger)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USERNAME=your-email@quikprint.ng
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=noreply@quikprint.ng
SMTP_FROM_NAME=QuikPrint NG
